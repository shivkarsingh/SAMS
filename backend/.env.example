PORT=4000
AI_SERVICE_URL=http://localhost:8000
AI_REQUEST_TIMEOUT_MS=30000
AI_HEALTH_TIMEOUT_MS=5000
JSON_BODY_LIMIT=35mb
MAX_CLASSROOM_CAPTURE_IMAGES=4
MAX_CLASSROOM_IMAGE_BYTES=8388608
AI_FACE_RECOGNITION_MODEL=ArcFace ResNet100@Glint360K (InsightFace antelopev2)
AI_EXECUTION_MODE=production
FRONTEND_ORIGIN=http://localhost:5173,http://0.0.0.0:5173
FRONTEND_APP_URL=http://localhost:5173
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/SAMS?appName=Cluster0

# Email delivery
EMAIL_ENABLED=true
EMAIL_FROM="SAMS Notifications <your-email@gmail.com>"
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RETRY_COUNT=2
EMAIL_RETRY_DELAY_MS=2000
EMAIL_QUEUE_CONCURRENCY=3
EMAIL_CONNECTION_TIMEOUT_MS=90000
EMAIL_TEST_RECIPIENT=your-test-recipient@example.com
EMAIL_TEST_KEY=change-this-test-key
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_EXPOSE_OTP_IN_RESPONSE=false
